generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  new
  assigned
  contacted
  won
  lost
}

enum LeadSource {
  property
  contact
  manual
  hero
}

enum NotifyStatus {
  pending
  sent
  failed
  skipped
}

model Lead {
  id              String     @id @default(uuid()) @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  status          LeadStatus @default(new)
  source          LeadSource
  propertyId      String?    @map("property_id")
  propertySlug    String?    @map("property_slug")
  propertyTitle   String?    @map("property_title")
  clientName      String?    @map("client_name")
  clientPhone     String?    @map("client_phone")
  clientEmail     String?    @map("client_email")
  message         String?
  goal            String?
  propertyType    String?    @map("property_type")
  budget          String?
  district        String?
  assignedSalesId String?    @map("assigned_sales_id")
  assignedAt      DateTime?  @map("assigned_at")
  notes           String?
  notifyStatus    NotifyStatus? @map("notify_status")
  notifiedAt      DateTime?  @map("notified_at")
  notifyError     String?    @map("notify_error")

  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@index([propertyId])
  @@index([assignedSalesId])
  @@map("leads")
}

model Property {
  id            String   @id
  slug          String   @unique
  titleAr       String   @map("title_ar")
  titleEn       String   @map("title_en")
  district      String
  type          String
  saleCategory  String   @default("primary") @map("sale_category")
  downPaymentPercent Int? @map("down_payment_percent")
  installmentYears   Int? @map("installment_years")
  price         Int
  area          Int
  bedrooms      Int
  bathrooms     Int
  finishingAr   String   @map("finishing_ar")
  finishingEn   String   @default("") @map("finishing_en")
  delivery      String   @default("Ready")
  parking       Int      @default(0)
  garden        Boolean  @default(false)
  roi           Float    @default(0)
  featured      Boolean  @default(false)
  published     Boolean  @default(true)
  tags          Json     @default("[]")
  images        Json     @default("[]")
  descriptionAr String   @map("description_ar") @db.Text
  descriptionEn String   @default("") @map("description_en") @db.Text
  amenities     Json     @default("[]")
  lat           Float    @default(30.18)
  lng           Float    @default(31.47)
  agentId       String   @map("agent_id")
  video         String?
  telegramListingCode String? @map("telegram_listing_code")
  telegramChatId      String? @map("telegram_chat_id")
  telegramMessageId   Int?    @map("telegram_message_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([published])
  @@index([telegramListingCode])
  @@index([featured])
  @@index([district])
  @@index([saleCategory])
  @@map("properties")
}

model SalesRep {
  id           String   @id
  name         String
  role         String
  saleCategory String   @default("primary") @map("sale_category")
  phone        String
  whatsapp     String
  telegramChatId String?  @map("telegram_chat_id")
  telegramUserId String?  @map("telegram_user_id")
  agentId      String?  @map("agent_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([saleCategory])
  @@map("sales_reps")
}

model TelegramGroupMember {
  chatId         String   @map("chat_id")
  telegramUserId String   @map("telegram_user_id")
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  username       String?
  isBot          Boolean  @default(false) @map("is_bot")
  isAdmin        Boolean  @default(false) @map("is_admin")
  firstSeenAt    DateTime @default(now()) @map("first_seen_at")
  lastSeenAt     DateTime @updatedAt @map("last_seen_at")

  @@id([chatId, telegramUserId])
  @@index([chatId])
  @@map("telegram_group_members")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model TelegramMessage {
  id           String   @id @default(uuid()) @db.Uuid
  chatId       String   @map("chat_id")
  messageId    Int      @map("message_id")
  chatTitle    String?  @map("chat_title")
  senderUserId String?  @map("sender_user_id")
  senderName   String?  @map("sender_name")
  text         String?  @db.Text
  hasMedia     Boolean  @default(false) @map("has_media")
  mediaType    String?  @map("media_type")
  mediaFileId  String?  @map("media_file_id")
  mediaPath    String?  @map("media_path")
  messageDate  DateTime @map("message_date")
  importedAt   DateTime @default(now()) @map("imported_at")
  raw          Json?

  listing TelegramListing?

  @@unique([chatId, messageId])
  @@index([chatId])
  @@index([messageDate(sort: Desc)])
  @@map("telegram_messages")
}

model TelegramListing {
  id           String   @id @default(uuid()) @db.Uuid
  messageDbId  String   @unique @map("message_db_id") @db.Uuid
  listingCode  String?  @map("listing_code")
  saleCategory String   @default("resale") @map("sale_category")
  propertyType String?  @map("property_type")
  district     String?
  compound     String?
  price        Int?
  area         Int?
  bedrooms     Int?
  bathrooms    Int?
  finishing    String?
  delivery     String?
  paymentNotes String?  @map("payment_notes") @db.Text
  rawText      String   @map("raw_text") @db.Text
  parsed       Json?
  propertyId   String?  @map("property_id")
  status       String   @default("parsed")
  createdAt    DateTime @default(now()) @map("created_at")

  message TelegramMessage @relation(fields: [messageDbId], references: [id], onDelete: Cascade)

  @@index([listingCode])
  @@index([district])
  @@index([status])
  @@map("telegram_listings")
}
