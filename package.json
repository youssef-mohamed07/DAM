{
  "name": "dam",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "node --env-file=.env.local -- ./node_modules/.bin/prisma generate",
    "db:push": "node --env-file=.env.local -- ./node_modules/.bin/prisma db push",
    "db:migrate": "node --env-file=.env.local -- ./node_modules/.bin/prisma migrate dev",
    "db:studio": "node --env-file=.env.local -- ./node_modules/.bin/prisma studio",
    "db:seed": "node --env-file=.env.local -- ./node_modules/.bin/tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.9.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
